---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Buy" description="Battle Beast cards are coming soon. Get notified when the store opens.">
  <section class="section coming-soon">
    <div class="container">
      <p class="eyebrow">Store</p>
      <h1 class="section-title">Coming Soon</h1>
      <p class="section-subtitle">
        We're still printing, sleeving, and obsessing over every card.<br />
        Drop us a line to get notified when the store opens.
      </p>
      <a href="mailto:hello@battlebeast.online?subject=Notify me when the store opens" class="btn btn-primary">
        Notify Me
      </a>
    </div>
  </section>
</Layout>

<style>
  .coming-soon {
    min-height: 60vh;
    display: flex;
    align-items: center;
    text-align: center;
  }

  .coming-soon .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .eyebrow {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
</style>
